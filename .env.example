# Copiar este archivo como .env y completar los valores
# cp .env.example .env

# Configuración SMTP para notificaciones por correo
# Gmail: activar "Contraseñas de aplicación" en myaccount.google.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Plataforma CUL

# Correo del administrador (recibe notificaciones de eliminación de usuarios)
ADMIN_EMAIL=

# URL de la base de datos (opcional)
# DATABASE_URL=postgresql://...

# JWT Authentication — generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookies: false en dev local (HTTP), true en producción (HTTPS)
COOKIE_SECURE=false